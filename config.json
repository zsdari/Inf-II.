{
  "filter": {
    "type": "AndFilter",
    "args": {
      "filters": [
        {
          "type": "LengthFilter",
          "args": {
            "min": 8,
            "max": 12
          }
        },
        {
          "type": "SpecialCharFilter",
          "args": {
            "special_chars": [
              ".",
              ",",
              "*"
            ],
            "min": 3
          }
        }
      ]
    }
  }
}